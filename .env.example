# Server
PORT=3001
NODE_ENV=development

# Client (prefix with VITE_ for client-side access)
VITE_WS_URL=ws://localhost:3001

# For Railway single-service deployment, VITE_WS_URL can be omitted.
# The client will connect to the same host using wss:// in production.

# VSCode Port Forwarding
# - Production mode: run `npm run build && npm start`, forward only 3001, open forwarded 3001 URL.
# - Dev mode: run `npm run dev`, forward 3000 and 3001.
#   Local forwarded localhost works automatically.
#   If using a public forwarded URL, either open 3000 and 3001 with matching VSCode URLs
#   or pass the WS URL manually: https://<forwarded-3000-url>/?ws=wss://<forwarded-3001-url>
